APP_HOST=0.0.0.0
APP_PORT=8000
APP_STATE_DB=data/app_state.db
DOWNLOADS_ROOT=downloads

# Optional: Google Drive upload
# Put your Google OAuth "Desktop app" client secret JSON path here.
GDRIVE_CLIENT_SECRET=client_secret.json
# Token will be created by `python3 main.py drive-auth`
GDRIVE_TOKEN_PATH=data/gdrive_token.json
# Optional default folder to upload into (Drive folder ID)
GDRIVE_FOLDER_ID=
# Use console auth instead of opening a browser (useful on headless machines)
GDRIVE_OAUTH_CONSOLE=false
